{
  "name": "rebase-buddy",
  "displayName": "Rebase Buddy",
  "description": "Interactive rebase editor with commit details — free and minimal",
  "version": "0.5.0",
  "publisher": "frontmatters",
  "author": "Frontmatters <hello@frontmatters.dev>",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/frontmatters/rebase-buddy.git"
  },
  "bugs": {
    "url": "https://github.com/frontmatters/rebase-buddy/issues"
  },
  "homepage": "https://github.com/frontmatters/rebase-buddy#readme",
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "rebase",
    "interactive rebase",
    "commit",
    "history"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "rebaser.editor",
        "displayName": "Rebase Buddy",
        "selector": [
          {
            "filenamePattern": "**/rebase-merge/git-rebase-todo"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "rebaser.enable",
        "title": "Rebase Buddy: Enable as Git rebase editor"
      },
      {
        "command": "rebaser.disable",
        "title": "Rebase Buddy: Disable (restore previous rebase editor)"
      }
    ],
    "configuration": {
      "title": "Rebase Buddy",
      "properties": {
        "rebaseBuddy.defaultOrder": {
          "type": "string",
          "enum": [
            "oldest-first",
            "newest-first"
          ],
          "enumDescriptions": [
            "Git's todo order: the rebase applies top to bottom.",
            "Log order: newest commit on top."
          ],
          "default": "newest-first",
          "description": "Default display order of the commit list when a rebase editor opens. The in-editor toggle overrides this for the session."
        },
        "rebaseBuddy.detailsWidth": {
          "type": "number",
          "default": 340,
          "minimum": 240,
          "maximum": 640,
          "description": "Initial width of the commit details panel in pixels. Dragging the splitter overrides this for the session."
        },
        "rebaseBuddy.confirmAbort": {
          "type": "boolean",
          "default": true,
          "description": "Require a second click to confirm Abort."
        },
        "rebaseBuddy.showBaseCommit": {
          "type": "boolean",
          "default": true,
          "description": "Show the base commit your changes are applied on top of, greyed out and read-only."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
